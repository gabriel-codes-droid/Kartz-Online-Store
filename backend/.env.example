# =========================================================
# Kartz backend environment configuration
# Copy this file to `.env` and replace placeholders with your
# real Flutterwave credentials before going to production.
# =========================================================

# ---- Server ----
PORT=8000
NODE_ENV=development

# ---- Database ----
MONGO_URI=mongodb://127.0.0.1:27017/kartz

# ---- Auth ----
# IMPORTANT: JWT_SECRET must be at least 32 characters. Use a
# random string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_random_string_at_least_32_characters_long_xx
JWT_EXPIRES_IN=7d

# ---- Payment Mode ----
# Set to 'mock' for testing without real payment processor
# Set to 'flutterwave' for real payments (requires Flutterwave keys)
PAYMENT_MODE=mock

# ---- Flutterwave (v3) ----
# Get keys at https://dashboard.flutterwave.com -> Settings -> API
# Test keys start with FLWTEST-, live keys start with FLWPUBK-/FLWSECK-
# Leave these as placeholder values to use mock payment mode
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
# Webhook secret hash. Set in Flutterwave dashboard -> Settings -> Webhooks
FLW_SECRET_HASH=replace_me_with_your_flutterwave_webhook_secret_hash

# ---- Platform payout account (optional, kept for future manual payouts) ----
PLATFORM_ACCOUNT_NUMBER=0000000000
